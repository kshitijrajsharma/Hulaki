# Copy to android/key.properties and fill in. Never commit the real file.
# Generate a keystore once:
#   keytool -genkey -v -keystore ~/fieldchat-release.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 -alias fieldchat
storeFile=/absolute/path/to/fieldchat-release.jks
storePassword=CHANGE_ME
keyAlias=fieldchat
keyPassword=CHANGE_ME
